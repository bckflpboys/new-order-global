{
    "manifest_version": 3,
    "key": "",
    "name": "New Order Global",
    "version": "1.0.0",
    "description": "AI-powered Chrome extension builder. Describe what you want, and AI creates custom tools for any website. Includes built-in YouTube enhancements.",
    "permissions": [
        "storage",
        "tabs",
        "scripting",
        "activeTab",
        "sidePanel"
    ],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["core/tool-runtime.js"],
            "runAt": "document_start"
        }
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "optional_host_permissions": [
        "https://www.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "icons/logo.png",
                "core/tool-runtime.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "options_page": "youtube.html",
    "action": {
        "default_icon": {
            "16": "icons/icon-blue-16.png",
            "48": "icons/icon-blue-48.png",
            "128": "icons/icon-blue-128.png"
        },
        "default_title": "New Order Global"
    },
    "side_panel": {
        "default_path": "popup.html"
    },
    "icons": {
        "16": "icons/icon-blue-16.png",
        "48": "icons/icon-blue-48.png",
        "128": "icons/icon-blue-128.png"
    }
}