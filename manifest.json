{
    "manifest_version": 3,
    "key": "",
    "name": "New Order Global",
    "version": "1.0.0",
    "description": "AI-powered Chrome extension builder. Describe what you want, and AI creates custom tools for any website. Includes built-in YouTube enhancements.",
    "permissions": [
        "storage",
        "tabs",
        "scripting",
        "activeTab",
        "sidePanel",
        "downloads",
        "alarms",
        "debugger",
        "clipboardRead"
    ],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["core/tool-runtime.js"],
            "runAt": "document_start"
        },
        {
            "matches": ["https://web.whatsapp.com/*"],
            "js": ["core/whatsapp-watcher.js"],
            "runAt": "document_idle"
        }
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "icons/logo.png",
                "core/tool-runtime.js",
                "core/doc-engine.js",
                "core/pdf-sandbox.js",
                "libs/pdf-lib.min.js",
                "libs/xlsx.mini.min.js",
                "libs/pizzip.min.js",
                "libs/docxtemplater.js",
                "libs/mammoth.browser.min.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "options_page": "youtube.html",
    "action": {
        "default_icon": {
            "16": "icons/logo-square-16.png",
            "32": "icons/logo-square-32.png",
            "48": "icons/logo-square-48.png",
            "128": "icons/logo-square-128.png"
        },
        "default_title": "New Order Global"
    },
    "side_panel": {
        "default_path": "popup.html"
    },
    "icons": {
        "16": "icons/logo-square-16.png",
        "32": "icons/logo-square-32.png",
        "48": "icons/logo-square-48.png",
        "128": "icons/logo-square-128.png"
    }
}