# New Order Global — API Server Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# MongoDB Connection String
# Get this from MongoDB Atlas: https://mongodb.com/atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.xxxxx.mongodb.net/neworder?retryWrites=true&w=majority

# JWT Secret — generate a strong random string
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_STRING

# OpenRouter API Key
# Get this from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# OpenRouter Model — which AI model to use for tool generation
# Recommended: anthropic/claude-sonnet-4-20250514, openai/gpt-4o, google/gemini-2.5-flash-preview
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514

# Lemon Squeezy (for payments)
# Get from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your_api_key_here
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret
LEMONSQUEEZY_PRO_VARIANT_ID=your_pro_variant_id
LEMONSQUEEZY_UNLIMITED_VARIANT_ID=your_unlimited_variant_id

# Frontend URL (for CORS & redirects)
FRONTEND_URL=https://global-order.32d.one

# Rate limits (per month)
AI_RATE_LIMIT_FREE=0
AI_RATE_LIMIT_PRO=50
AI_RATE_LIMIT_UNLIMITED=9999
